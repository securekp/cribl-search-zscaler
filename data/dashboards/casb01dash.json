      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_casb_dataset} login='$user$' dlpdictionaries!='None' dlpdictionaries!='' | summarize by dlpdictionaries", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "casb_bar_dlp",
