      "title": "User Selection"
    },
    {
      "config": {},
      "search": {"type": "inline", "runMode": "lastRun", "query": "${pack(cribl-search-zscaler).zscaler_casb_dataset} login='$user$' | summarize count()", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "casb_cnt_events",
