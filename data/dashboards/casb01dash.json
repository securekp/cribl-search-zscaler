      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_casb_dataset} login='$user$' | summarize by action", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "casb_pie_action",
