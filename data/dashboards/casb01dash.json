      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_casb_dataset} login='$user$' | summarize count() by login | sort by count desc | limit 10", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "casb_bar_users",
