{
  "created": 1730000000000,
  "modified": 1730000000000,
  "createdBy": "pack",
  "modifiedBy": "pack",
  "schedule": {"enabled": false, "cronSchedule": "0 0 * * *", "tz": "UTC", "keepLastN": 2},
  "name": "ZScaler Audit Logs",
  "cacheTTLSeconds": 3600,
  "elements": [
    {
      "config": {"defaultValue": {"earliest": "-1h", "latest": "now", "timezone": "local"}},
      "id": "audit_time_range",
      "inputId": "time_range",
      "type": "input.timerange",
      "layout": {"x": 0, "y": 0, "w": 2, "h": 2},
      "variant": "input",
      "title": "Time Range"
    },
    {
      "config": {"defaultValue": "*", "field": "adminid"},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} | summarize by adminid", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_admin_select",
      "inputId": "user",
      "type": "input.dropdown",
      "layout": {"x": 2, "y": 0, "w": 2, "h": 2},
      "variant": "input",
      "title": "Admin Selection"
    },
    {
      "config": {},
      "search": {"type": "inline", "runMode": "lastRun", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize count()", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_cnt_events",
      "layout": {"x": 0, "y": 0, "w": 3, "h": 2},
      "type": "counter.single",
      "title": "Total Events"
    },
    {
      "config": {},
      "search": {"type": "inline", "runMode": "lastRun", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize dcount(adminid)", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_cnt_admins",
      "layout": {"x": 3, "y": 0, "w": 3, "h": 2},
      "type": "counter.single",
      "title": "Admins"
    },
    {
      "config": {},
      "search": {"type": "inline", "runMode": "lastRun", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' result='SUCCESS' | summarize count()", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_cnt_success",
      "layout": {"x": 6, "y": 0, "w": 3, "h": 2},
      "type": "counter.single",
      "title": "Successful"
    },
    {
      "config": {},
      "search": {"type": "inline", "runMode": "lastRun", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' result!='SUCCESS' | summarize count()", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_cnt_failed",
      "layout": {"x": 9, "y": 0, "w": 3, "h": 2},
      "type": "counter.single",
      "title": "Failed"
    },
    {
      "config": {"onClickAction": {"type": "Run a new search", "search": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' action='$value$'"}, "legend": {"position": "None"}},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize count() by action | sort by count desc | limit 10", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_bar_action",
      "layout": {"x": 0, "y": 2, "w": 6, "h": 4},
      "type": "chart.horizontalBar",
      "title": "Top Actions"
    },
    {
      "config": {"onClickAction": {"type": "Run a new search", "search": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' result='$value$'"}, "legend": {"position": "None"}},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize by result", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_pie_result",
      "layout": {"x": 6, "y": 2, "w": 6, "h": 4},
