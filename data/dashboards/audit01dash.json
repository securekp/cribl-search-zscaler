      "title": "Success vs Failure"
    },
    {
      "config": {"onClickAction": {"type": "Run a new search", "search": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | extend category_norm=tolower(category) | where category_norm='$value$'"}, "legend": {"position": "None"}},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize count() by category_norm=tolower(category) | sort by count desc | limit 10", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_bar_category",
      "layout": {"x": 0, "y": 6, "w": 6, "h": 4},
      "type": "chart.horizontalBar",
      "title": "Events by Category"
    },
    {
      "config": {"onClickAction": {"type": "Run a new search", "search": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' interface='$value$'"}, "legend": {"position": "None"}},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize by interface", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_pie_interface",
      "layout": {"x": 6, "y": 6, "w": 6, "h": 4},
      "type": "chart.pie",
      "title": "Events by Interface (API vs UI)"
    },
    {
      "config": {"onClickAction": {"type": "Run a new search", "search": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$value$'"}, "legend": {"position": "None"}},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize count() by adminid | sort by count desc | limit 10", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_bar_admins",
      "layout": {"x": 0, "y": 10, "w": 6, "h": 4},
      "type": "chart.pie",
      "title": "Top Admins by Activity"
    },
    {
      "config": {"onClickAction": {"type": "Run a new search", "search": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | extend subcategory_norm=tolower(subcategory) | where subcategory_norm='$value$'"}, "legend": {"position": "None"}},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' subcategory!='None' subcategory!='' | summarize count() by subcategory_norm=tolower(subcategory) | sort by count desc | limit 10", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_bar_subcategory",
      "layout": {"x": 6, "y": 10, "w": 6, "h": 4},
      "type": "chart.horizontalBar",
      "title": "Events by Subcategory"
    },
    {
      "config": {},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' result!='SUCCESS' | summarize by adminid, action, result, errorcode, interface | order by count desc", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_table_failures",
      "layout": {"x": 0, "y": 14, "w": 6, "h": 4},
      "type": "list.table",
      "title": "Failed Events (Admin, Action, Result, Error Code)"
    },
    {
      "config": {},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize by action, category_norm=tolower(category), interface, result | order by count desc", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_table_activity",
      "layout": {"x": 6, "y": 14, "w": 6, "h": 4},
      "type": "list.table",
      "title": "Activity Summary (Action, Category, Interface, Result)"
    },
    {
      "config": {},
      "search": {"type": "inline", "query": "${pack(cribl-search-zscaler).zscaler_audit_dataset} adminid='$user$' | summarize by adminid, clientip | order by count desc", "earliest": "$time_range.earliest$", "latest": "$time_range.latest$", "timezone": "$time_range.timezone$"},
      "id": "audit_table_admin_clientip",
      "layout": {"x": 0, "y": 18, "w": 12, "h": 4},
      "type": "list.table",
      "title": "Admin by Login Source (clientip)"
    }
  ],
  "disabled": false,
  "description": "Analysis of ZScaler Audit logs: admin activity, sign-in/out, categories, success vs failure, and interface (API/UI)."
}
